<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup/transfer rules.

  The app's private photo copies and Room database must never leave the device (see
  CLAUDE.md → Photo Storage Strategy). android:allowBackup is already false, so no cloud
  backup runs; these rules additionally exclude everything from device-to-device transfer
  so a phone migration can't sweep the private photo copies off-device either.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
